# ===== Telegram & OpenAI =====
TELEGRAM_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://yungpt.com/v1
BOT_DB_PATH=bot_data.sqlite3

# ===== Owner 身份 =====
# 支持英文逗号、中文逗号、分号、换行作为分隔符；前缀 @ 会被自动去掉
OWNER_USERNAMES=jinlid,pay9l
# OWNER_CHAT_ID 是历史单值字段；OWNER_CHAT_IDS 是新列表字段，二者会自动合并
OWNER_CHAT_ID=7256055877
OWNER_CHAT_IDS=7256055877
# OWNER_USER_IDS：owner 的 Telegram user.id 列表（推荐配置，比 username 稳定）。
# 不配置时会 fallback 用 OWNER_CHAT_IDS（私信里 chat_id 通常等于 user_id）。
# is_owner 会优先按 user.id 匹配，再 fallback username。
OWNER_USER_IDS=7256055877

# ===== Business 风控 =====
AD_KEYWORDS=加微信,加v,代理,招商,返利,兼职,刷单,送彩金,点击链接,下载app
# 阿君在 business 窗口里自己发完消息后的静默窗口（秒）。
# 在这段时间内，对方发来的消息只入库不调用模型，避免被机器人立刻接走。
# 默认 6 秒（本轮从 8 调到 6，降低误伤）；可按需覆盖。
SELF_MESSAGE_IGNORE_SECONDS=6

# ===== 历史会话滑动窗口 =====
# 进程内 user_histories 的双限制：条数 + 字符总长度。
HISTORY_MAX_MESSAGES=60
HISTORY_MAX_CHARS=4000

# ===== 模型分工（不要随便改）=====
CORE_MODEL=gpt-5.5
LIGHT_MODEL=gpt-5.4-mini
VISION_MODEL=gemini-3.1-flash-lite
BACKUP_MODEL=deepseek-v4-flash
TRANSCRIBE_MODEL=whisper-1
TRANSCRIBE_FALLBACK_MODELS=gpt-4o-mini-transcribe,gpt-4o-transcribe
# IMAGE_MODEL：图像创作功能（/plog /magnet /y2k /poster）使用的 OpenAI-compatible 模型
# 默认 gpt-image-2，可在不同上游服务上覆盖
IMAGE_MODEL=gpt-image-2
# TEXT_IMAGE_MODEL：纯文字生图 /img 使用的模型，默认 flux-1.1-pro
TEXT_IMAGE_MODEL=flux-1.1-pro
# TEXT_IMAGE_FALLBACK_MODELS：主模型 429/model_not_found/上游饱和时，按顺序降级的实际可用模型
TEXT_IMAGE_FALLBACK_MODELS=qwen-image-2.0-pro,qwen-image-2.0,doubao-seedream-4-0-250828
# IMAGE_TEXT_MODEL：图 + 文字生图/改图（/改图 /生图 /图生图）使用的模型，默认 flux.1-kontext-pro
IMAGE_TEXT_MODEL=flux.1-kontext-pro
# IMAGE_EDIT_FALLBACK_MODELS：image edit 主模型失败时，按顺序降级的实际可用 edit 模型
IMAGE_EDIT_FALLBACK_MODELS=qwen-image-edit-plus,qwen-image-2.0-pro,doubao-seedream-4-0-250828
# I2V_VIDEO_MODEL：图生视频（图生15秒视频）使用的大模型，默认 wan2.6-i2v
# （此前默认 wan2.6-i2v-flash 上游不存在，会 model_not_found）。
# 别名 IMAGE_TO_VIDEO_MODEL 若设置则优先生效（二者同一功能）。复用 OPENAI_BASE_URL / OPENAI_API_KEY。
I2V_VIDEO_MODEL=wan2.6-i2v
# IMAGE_TO_VIDEO_MODEL=wan2.6-i2v
# I2V_VIDEO_FALLBACK_MODELS：i2v 主模型被拒（429/model_not_found）时按顺序降级
I2V_VIDEO_FALLBACK_MODELS=wan2.6-i2v
# I2V_ENDPOINT_PATHS：图生视频接口路径降级链；某路径 404/405 时换下一个（兼容不同中转）
I2V_ENDPOINT_PATHS=videos/generations,video/generations,videos/generate,images/generations
# 图生视频默认时长（秒），默认 15
I2V_VIDEO_DURATION_SECONDS=15
# 异步出片（接口返回 task/job id）时的轮询总超时与间隔（秒）
I2V_POLL_TIMEOUT_SECONDS=180
I2V_POLL_INTERVAL_SECONDS=5

# ===== 贴纸 file_id（可留空，留空时模型即使选了 sticker_type 也不会发，不会报错）=====
STICKER_LAUGH=
STICKER_HAPPY=
STICKER_SHY=
STICKER_THINKING=
STICKER_LOVE=

# ===== 每天一个笑话（daily joke）：内部定时任务 =====
# 默认：每天 21:00 (Asia/Hong_Kong) 给 owner + 贝贝（meta.xiaopang_chat_id）各发一条。
# 把 DAILY_JOKE_ENABLED 设为 0/false/no/off 可彻底关掉。
DAILY_JOKE_ENABLED=1
DAILY_JOKE_HOUR=21
DAILY_JOKE_MINUTE=0
DAILY_JOKE_TZ=Asia/Hong_Kong
# source mode：mixed（默认，先抓网络，失败回落 AI）/ network（仅抓网络）/ ai（纯本地生成）
DAILY_JOKE_SOURCE_MODE=mixed
# 可选：自配的笑话 JSON 接口列表（首个成功的即用）。逗号分隔；留空时 mixed 直接走 AI 兜底。
DAILY_JOKE_NETWORK_URLS=
# 接收人：逗号分隔，关键字 owner / beibei
# owner 走 OWNER_CHAT_IDS；beibei 走 meta.xiaopang_chat_id + DAILY_JOKE_BEIBEI_CHAT_IDS
DAILY_JOKE_RECIPIENTS=owner,beibei
# 备选贝贝 chat_id（当 meta 里还没记到她的 chat_id 时使用）
DAILY_JOKE_BEIBEI_CHAT_IDS=
